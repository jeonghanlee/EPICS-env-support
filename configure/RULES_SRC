#
.DEFAULT_GOAL := vars

.PHONY: default init distclean deinit

default: vars

.PHONY: init clone update deinit distclean

## Clone Source
init: clone

# gitclone use '-C' option, so git version should be more than 1.8.5. CentOS7 git is imcompatiable.
#
clone: clone.modules

conf: conf.modules

conf.gz: conf.gz.modules

conf.show: conf.modules.show

deinit: distclean

## Clean Source
distclean: distclean.modules
	-rm -f $(TOP)/*.local
	-rm -f $(TOP)/configure/*.local

deinit: distclean

build: conf build.modules

build.gz: conf.gz build.modules

distclean: distclean.modules distclean.modulesgen

distclean.modulesgen:
	-rm -rf $(TOP)/configure/MODULESGEN.mk

symlinks: symlinks.modules

.PHONY: conf.base

# Check if EPICS_BASE is defined and non-empty.
# This make configuration quick for the integration testing with EPICS-env revision
ifneq ($(strip $(EPICS_BASE)),)
conf.base:
	@printf "Configuring INSTALL_LOCATION to %s\n" "$(EPICS_BASE)"
	$(RM) $(TOP)/configure/CONFIG_SITE.local
	printf "INSTALL_LOCATION=%s\n" "$(EPICS_BASE)" > $(TOP)/configure/CONFIG_SITE.local
endif

null:
	@echo ""
